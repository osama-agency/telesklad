# PostgreSQL Database Configuration
POSTGRES_DB=telesite
POSTGRES_USER=telesite_user
POSTGRES_PASSWORD=TeleS1te_2025_SecurePass!

# Application Configuration
NODE_ENV=production
PORT=3000
NEXTAUTH_SECRET=TeleS1te_NextAuth_2025_SecureSecret_Key!
NEXTAUTH_URL=https://dsgrating.ru

# Database URL (автоматически формируется из переменных выше)
DATABASE_URL=postgresql://telesite_user:TeleS1te_2025_SecurePass!@postgres:5432/telesite?schema=public

# Backend Configuration
BACKEND_URL=http://localhost:3011

# Optional: External PostgreSQL (если используете внешнюю БД)
# DATABASE_URL=postgresql://username:password@external-host:5432/database_name

# Telegram Bot (если используется)
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_telegram_chat_id

# Email Configuration (если используется)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# Security
# JWT_SECRET=your_jwt_secret_here
